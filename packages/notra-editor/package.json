{
	"name": "notra-editor",
	"type": "module",
	"version": "0.2.0",
	"description": "A Markdown-first rich text editor for React",
	"license": "MIT",
	"keywords": [
		"editor",
		"markdown",
		"rich-text",
		"tiptap",
		"react",
		"notion"
	],
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		},
		"./themes/default/shared.css": "./dist/themes/default/shared.css",
		"./themes/default/editor.css": "./dist/themes/default/editor.css",
		"./themes/default/reader.css": "./dist/themes/default/reader.css",
		"./styles/globals.css": "./dist/styles/globals.css"
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup && pnpm build:css",
		"build:css": "postcss src/styles/globals.css -o dist/styles/globals.css",
		"dev": "tsup --watch",
		"test": "vitest run --passWithNoTests",
		"test:watch": "vitest",
		"pub:beta": "pnpm build && pnpm publish --tag beta --access public",
		"pub:release": "pnpm build && pnpm publish --access public"
	},
	"peerDependencies": {
		"react": "^18.0.0 || ^19.0.0",
		"react-dom": "^18.0.0 || ^19.0.0"
	},
	"dependencies": {
		"@radix-ui/react-slot": "^1.2.4",
		"@tiptap/core": "^3.22.4",
		"@tiptap/extension-link": "^3.22.4",
		"@tiptap/extension-list": "^3.22.4",
		"@tiptap/pm": "^3.22.4",
		"@tiptap/react": "^3.22.4",
		"@tiptap/starter-kit": "^3.22.4",
		"@tiptap/static-renderer": "^3.22.4",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"lucide-react": "^1.9.0",
		"tailwind-merge": "^3.5.0",
		"tiptap-markdown": "^0.8.10"
	},
	"devDependencies": {
		"@tailwindcss/postcss": "^4.2.4",
		"@testing-library/jest-dom": "^6.6.3",
		"@testing-library/react": "^16.3.0",
		"@types/react": "19.2.2",
		"@types/react-dom": "19.2.2",
		"jsdom": "^26.1.0",
		"postcss": "^8.5.10",
		"postcss-cli": "^11.0.1",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"tailwindcss": "^4.2.4",
		"tsup": "^8.4.0",
		"typescript": "^5.8.0",
		"vitest": "^4.0.18"
	}
}
